# ── Local development only ──────────────────────────────────────────
# 1. Copy this file to ".env.local"
# 2. Paste your Groq API key below
# 3. NEVER commit .env.local (it is already in .gitignore)
#
# On Vercel you do NOT use this file — set GROQ_API_KEY in
# Project → Settings → Environment Variables instead.

GROQ_API_KEY=your_groq_api_key_here

# Optional — override the model. Default is llama-3.3-70b-versatile.
# Faster/cheaper alternative: llama-3.1-8b-instant
# GROQ_MODEL=llama-3.3-70b-versatile
